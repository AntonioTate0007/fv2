<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark base theme — Compose owns colors at runtime, this just makes the
         system-UI bars render correctly before Compose mounts. -->
    <style name="Theme.Pumps" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">#0B0D10</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#0B0D10</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
