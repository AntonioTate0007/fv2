<?xml version="1.0" encoding="utf-8"?>
<!--
    Pumps launcher icon — flame silhouette behind an upward chart line.
    Mirrors the PNG icon used by the PWA so both ship with the same brand.
    108dp canvas, 66dp safe area (the standard adaptive-icon convention).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Hot-orange flame -->
    <path
        android:fillColor="#FF5E3A"
        android:pathData="M54,30 L82,82 L26,82 Z" />
    <!-- Upward chart line -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M36,72 L46,64 L54,68 L64,56 L74,42 L78,46 L66,60 L54,72 L46,68 L40,76 Z" />
    <!-- Gold signal dot -->
    <path
        android:fillColor="#F5B800"
        android:pathData="M54,68 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0" />
</vector>
