# Copy to .env and fill in for local development:
#   cp .env.example .env
#   uvicorn main:app --reload

# ── Required in production ─────────────────────────────────────────────────────

# Bearer token the Android app must send on every /v1/* request. Generate with
#   openssl rand -hex 32
# Same value must be baked into the APK via local.properties (api.auth.token=...)
FORTRESS_API_TOKEN=

# ── Broker (Alpaca) — leave blank for mock-data fallback ───────────────────────

# From https://app.alpaca.markets → API Keys (use the PAPER tab while testing)
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Defaults to "true" (paper trading). Set to "false" only when you intend to
# place REAL orders against your live brokerage account. There is no other guard.
ALPACA_PAPER=true

# ── Risk Officer (Gemini) ──────────────────────────────────────────────────────

# From https://aistudio.google.com — enables real Risk Officer replies on the
# server side. (The Android app can also call Gemini directly with its own key
# via Settings — that path doesn't need this env var.)
GEMINI_API_KEY=

# ── Optional ───────────────────────────────────────────────────────────────────

# Full JSON of a Firebase Admin SDK service-account key on ONE line. Required
# only if you want server-initiated push notifications (currently unused — the
# app polls via WorkManager).
FIREBASE_CREDENTIALS_JSON=

# Bearer required on /admin/* routes. Leave blank to disable admin auth in dev.
ADMIN_TOKEN=
